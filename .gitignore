# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing (tests are kept local, not pushed)
/coverage
coverage/
/tests/
tests/
*.lcov

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# testing / e2e artifacts (match anywhere, never push)
playwright-report/
test-results/
.playwright/
.playwright-mcp/

# typescript
*.tsbuildinfo
next-env.d.ts

# local screenshots / mcp artifacts
*.png
*.jpg
*.jpeg
*.webp
!public/**/*.png
!public/**/*.jpg
!public/**/*.jpeg

# local setup runbooks / handoff notes (infra endpoints + test creds — keep local)
/docs/
