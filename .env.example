# MoneyFlow — copy to .env.local and fill in. Never commit real secrets.
# Neon serverless Postgres connection strings.
# Pooled endpoint (has "-pooler" in host) — used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"
# Direct/unpooled endpoint (no "-pooler") — used by drizzle-kit migrations.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Neon Auth (hosted Better Auth). NEON_AUTH_BASE_URL = the "Auth URL" from the
# Neon console (e.g. https://ep-xxxx.neonauth.REGION.aws.neon.tech/neondb/auth).
NEON_AUTH_BASE_URL="https://ep-xxxx.neonauth.REGION.aws.neon.tech/neondb/auth"
# Signs the session cookie (HMAC). Must be 32+ chars. Generate: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET="change-me-at-least-32-characters-long"

# Set to "true" to show email/password login fields (automation/testing only).
# Keep "false"/unset in production so the sign-in UI stays Google-only.
NEXT_PUBLIC_ENABLE_PASSWORD_AUTH="false"

APP_VERSION="0.1.0"
